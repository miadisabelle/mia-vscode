{
	"name": "story-monitor",
	"displayName": "Mia Story Monitor",
	"description": "Live narrative event dashboard for Mia Code",
	"version": "0.3.0",
	"publisher": "mia",
	"license": "MIT",
	"engines": { "vscode": "^1.96.0" },
	"activationEvents": [
		"onView:mia.sessionExplorer",
		"onCommand:mia.storyMonitor.open",
		"onCommand:mia.storyMonitor.toggleAmbient",
		"onCommand:mia.storyMonitor.logBeat",
		"onCommand:mia.storyMonitor.setIntent",
		"onCommand:mia.storyMonitor.endSession",
		"onCommand:mia.storyMonitor.exportSession",
		"onCommand:mia.storyMonitor.setPhase",
		"workspaceContains:**/.pde/*.json",
		"workspaceContains:**/.coaia/**/*.jsonl"
	],
	"main": "./src/extension.js",
	"extensionDependencies": ["mia.three-universe"],
	"contributes": {
		"commands": [
			{
				"command": "mia.storyMonitor.open",
				"title": "Mia: Open Story Monitor Dashboard",
				"icon": "$(pulse)"
			},
			{
				"command": "mia.storyMonitor.toggleAmbient",
				"title": "Mia: Toggle Ambient Story Indicators",
				"icon": "$(eye)"
			},
			{
				"command": "mia.storyMonitor.logBeat",
				"title": "Mia: Log Story Beat",
				"icon": "$(record)"
			},
			{
				"command": "mia.storyMonitor.endSession",
				"title": "Mia: End Current Session",
				"icon": "$(debug-stop)"
			},
			{
				"command": "mia.storyMonitor.setIntent",
				"title": "Mia: Set Session Intent",
				"icon": "$(edit)"
			},
			{
				"command": "mia.storyMonitor.exportSession",
				"title": "Mia: Export Session as Narrative",
				"icon": "$(export)"
			},
			{
				"command": "mia.storyMonitor.setPhase",
				"title": "Mia: Set Session Phase",
				"icon": "$(symbol-event)"
			}
		],
		"menus": {
			"view/title": [
				{ "command": "mia.storyMonitor.logBeat", "when": "view == mia.sessionExplorer", "group": "navigation" },
				{ "command": "mia.storyMonitor.open", "when": "view == mia.sessionExplorer", "group": "navigation" }
			]
		}
	}
}
