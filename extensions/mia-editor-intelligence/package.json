{
	"name": "mia-editor-intelligence",
	"displayName": "Mia Editor Intelligence",
	"description": "CodeLens, hover, decorations, inline suggestions, and diagnostics for narrative-aware editing",
	"version": "0.2.0",
	"publisher": "mia",
	"license": "MIT",
	"engines": { "vscode": "^1.96.0" },
	"activationEvents": ["onStartupFinished", "onLanguage:json", "onLanguage:markdown", "workspaceContains:**/.pde/**", "workspaceContains:**/.coaia/**"],
	"main": "./src/extension.js",
	"extensionDependencies": ["mia.three-universe"],
	"contributes": {
		"commands": [
			{
				"command": "mia.editorIntelligence.refreshDecorations",
				"title": "Mia: Refresh Editor Decorations",
				"icon": "$(refresh)"
			},
			{
				"command": "mia.editorIntelligence.analyzeFile",
				"title": "Mia: Analyze Current File (Editor Intelligence)",
				"icon": "$(search)"
			},
			{
				"command": "mia.editorIntelligence.clearDiagnostics",
				"title": "Mia: Clear All Diagnostics",
				"icon": "$(clear-all)"
			},
			{
				"command": "mia.editorIntelligence.toggleDecorations",
				"title": "Mia: Toggle Editor Decorations",
				"icon": "$(eye)"
			}
		],
		"languages": [
			{
				"id": "pde-json",
				"aliases": ["PDE Decomposition"],
				"extensions": [],
				"filenames": [],
				"filenamePatterns": ["**/.pde/*.json"]
			},
			{
				"id": "coaia-jsonl",
				"aliases": ["COAIA Chart"],
				"extensions": [],
				"filenames": [],
				"filenamePatterns": ["**/.coaia/**/*.jsonl"]
			}
		]
	}
}
